PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=<local-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<server-only, never PUBLIC_>

# ── Stripe (Phase 3 — test mode). Server-only secrets. ──
STRIPE_SECRET_KEY=<sk_test_... — server-only, never PUBLIC_>
STRIPE_WEBHOOK_SECRET=<whsec_... from `stripe listen` or the dashboard endpoint>

# ── Stripe webhook system user (profile must be is_admin). The webhook signs in as this user
#    via signInWithPassword on the anon key, then calls the admin-only money RPCs. NO service-role. ──
SYSTEM_USER_EMAIL=<system@yourdomain — a real auth user whose profile.is_admin = true>
SYSTEM_USER_PASSWORD=<server-only password for that user>

# ── Resend (Phase 7 — transactional email). Server-only secrets. ──
# Get your API key at https://resend.com — free tier covers low-volume notification emails.
RESEND_API_KEY=<re_... — server-only, never PUBLIC_>
# Optional: override the From address (defaults to "AI Safety Ideas <notifications@aisafetyideas.com>")
# RESEND_FROM=AI Safety Ideas <notifications@yourdomain.com>
